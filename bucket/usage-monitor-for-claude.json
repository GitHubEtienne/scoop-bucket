{
    "version": "1.10.0",
    "description": "Monitor Claude AI API usage and costs in real time on Windows",
    "homepage": "https://github.com/jens-duttke/usage-monitor-for-claude",
    "license": "MIT",
    "url": "https://github.com/jens-duttke/usage-monitor-for-claude/releases/download/v1.10.0/UsageMonitorForClaude.exe",
    "hash": "1e26d5fbc660c51194bab1a94bf2d18d70449ce65bbab4dc005b6e99f02d202f",
    "pre_install": [
        "if (!(Test-Path \"$dir\\usage-monitor-settings.json\")) {",
        "    Set-Content -Path \"$dir\\usage-monitor-settings.json\" -Value '{\"language\": \"en\"}' -Encoding UTF8",
        "}"
    ],
    "post_install": [
        "Set-Content -Path \"$dir\\LaunchMonitor.cmd\" -Value \"@echo off`r`necho Refreshing Claude Code authentication...`r`ncall \\\"%APPDATA%\\npm\\claude.cmd\\\" update >nul 2>&1`r`necho Starting Usage Monitor...`r`nstart `\"\\\" \\\"%~dp0UsageMonitorForClaude.exe\\\"\" -Encoding ASCII",
        "$regPath = 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run'",
        "New-ItemProperty -Path $regPath -Name 'UsageMonitorForClaude' -Value \"\\\"$dir\\UsageMonitorForClaude.exe\\\"\" -PropertyType String -Force | Out-Null",
        "Write-Host 'Autostart registered.'"
    ],
    "pre_uninstall": [
        "Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'UsageMonitorForClaude' -ErrorAction SilentlyContinue"
    ],
    "bin": [
        ["UsageMonitorForClaude.exe", "usage-monitor-for-claude"]
    ],
    "shortcuts": [
        ["UsageMonitorForClaude.exe", "Usage Monitor for Claude"]
    ],
    "persist": "usage-monitor-settings.json",
    "checkver": {
        "github": "https://github.com/jens-duttke/usage-monitor-for-claude"
    },
    "autoupdate": {
        "url": "https://github.com/jens-duttke/usage-monitor-for-claude/releases/download/v$version/UsageMonitorForClaude.exe"
    }
}
